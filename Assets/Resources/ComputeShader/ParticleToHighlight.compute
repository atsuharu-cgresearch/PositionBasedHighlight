        // ループの中の交差判定部分をこれに置き換えます
        float2 p0 = _Particles[edge0].x;
        float2 p1 = _Particles[edge1].x;

        // 1. 線分が現在のY座標（rayOrigin.y）を上下に跨いでいるかチェック
        if ((p0.y > rayOrigin.y) != (p1.y > rayOrigin.y))
        {
            // 2. 跨いでいる場合、交差点のX座標を「相似の比」で計算
