#pragma kernel CS_Main

#include "Assets/Resources/hlsl/Struct_ParticleData.hlsl"

StructuredBuffer<ParticleData> _Particles;
StructuredBuffer<int> _EdgeIndices;
RWTexture2D<float4> _ResultTexture;

uint _NumEdges;
uint _TexSize;
float4 _Transform;

float Cross2D(float2 a, float2 b)
{
    return a.x * b.y - a.y * b.x;
}

// レイと線分の交差判定
bool RayIntersectLine(float2 rayOrigin, float2 rayDirection, float2 lineStart, float2 lineEnd)
{
    float2 v1 = rayOrigin - lineStart;
    float2 v2 = lineEnd - lineStart;
    float2 v3 = float2(-rayDirection.y, rayDirection.x); // rayDirection の垂直ベクトル

    float denom = dot(v2, v3);

    // ほとんど平行な場合
    if (abs(denom) < 1e-6) return false;

    float t1 = Cross2D(v2, v1) / denom;
    float t2 = dot(v1, v3) / denom;

    return (t1 >= 0.0 && t2 >= 0.0 && t2 <= 1.0);
}

float2 LocalToWorld(float2 pLocal, float2 pos, float scale, float angle)
{
    float2 p = pLocal * scale;

    float c = cos(angle);
    float s = sin(angle);

    float2 pRot;
    pRot.x =  c * p.x - s * p.y;
    pRot.y =  s * p.x + c * p.y;

    return pRot + pos;
}

[numthreads(8, 8, 1)]
void CS_Main (uint3 id : SV_DispatchThreadID)
{
    if (id.x >= _TexSize || id.y >= _TexSize) return;

    // 初期化
