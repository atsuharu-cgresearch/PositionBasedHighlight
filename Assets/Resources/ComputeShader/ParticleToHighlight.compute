    // この画素と対応する、シミュレーション空間の座標
    float2 worldPos = LocalToWorld(uv - float2(0.5, 0.5), _Transform.xy, _Transform.z, _Transform.w);

    float2 rayOrigin = worldPos;
    float2 rayDirection = float2(1, 0);

    uint intersectCount = 0;
    bool intersect = false;
